[user]
	name = Isai Gordeev
	email = isaigordeev@gmail.com
	signingkey = E32BE35A
[commit]
	gpgsign = true
[alias]
	lg = log --all --oneline --graph --decorate
	lgc = log --oneline --graph --decorate HEAD @{u}
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = true
	; Look like a plain `git diff`: keep delta only for paging/navigation.
	; - line-numbers off -> no gutter (default git has none)
	; - +/- styles are foreground-only and OMIT the `syntax` keyword, so whole
	;   changed lines are just red/green with no background highlight and no
	;   syntax coloring (the `syntax` keyword is what enables both in delta).
	; - emph styles match the line styles -> no brighter within-line emphasis.
	; - zero-style normal -> context lines in the terminal's default color.
	; Re-enable rich delta by setting these back to `syntax` and line-numbers.
	line-numbers = false
	minus-style = red
	minus-emph-style = red
	plus-style = green
	plus-emph-style = green
	zero-style = normal
	; Page with quit-if-one-screen: short diffs auto-quit and stay in the
	; terminal (feels like stdout), long diffs open in less (wrapped +
	; navigable), -X keeps content in scrollback on quit.
	paging = auto
	pager = less -RFX
	; jj-like minimalism: drop the box/rule "boarding lines".
	hunk-header-style = omit
	file-decoration-style = none
	file-style = blue
	; drop the "Δ" modified-file symbol -- show just the path
	file-modified-label = ""
[merge]
	conflictStyle = diff3
[diff]
	colorMoved = default
[pager]
	diff = true
[sendemail]
	smtpServer = smtp.gmail.com
	smtpServerPort = 587
	smtpEncryption = tls
	smtpUser = isai.gordeev.2022@polytechnique.org
